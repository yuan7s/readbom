<Window x:Class="readbom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SW 属性/BOM工具" Height="720" Width="1200" MinHeight="640" MinWidth="980" WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ToolbarWideButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="MinWidth" Value="112"/>
        </Style>
        <Style x:Key="ToolbarOptionTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style x:Key="ToolbarGroupTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="DimGray"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="ToolbarGroupBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#D8D8D8"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="0,0,10,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#D8D8D8" BorderThickness="0,0,0,1" Padding="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource ToolbarGroupBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ToolbarGroupTitleStyle}">连接读取</TextBlock>
                        <WrapPanel>
                            <Button Name="ConnectButton" Style="{StaticResource ToolbarWideButtonStyle}" Click="ConnectButton_OnClick">连接 SW</Button>
                            <Button Name="ReadButton" Style="{StaticResource ToolbarWideButtonStyle}" Click="ReadButton_OnClick">读取属性/BOM</Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource ToolbarGroupBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ToolbarGroupTitleStyle}">写入处理</TextBlock>
                        <WrapPanel>
                            <Button Name="SaveToSwButton" Style="{StaticResource ToolbarWideButtonStyle}" Click="SaveToSwButton_OnClick">保存到 SW</Button>
                            <Button Name="RelocateFilesButton" Style="{StaticResource ToolbarWideButtonStyle}" Click="RelocateFilesButton_OnClick">复制重装</Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource ToolbarGroupBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ToolbarGroupTitleStyle}">表格操作</TextBlock>
                        <WrapPanel>
                            <Button Name="HeaderFilterButton" Style="{StaticResource ToolbarButtonStyle}" Click="HeaderFilterButton_OnClick">表头筛选</Button>
                            <Button Name="CopyColumnButton" Style="{StaticResource ToolbarButtonStyle}" Click="CopyColumnButton_OnClick">复制列</Button>
                            <Button Name="FillColumnButton" Style="{StaticResource ToolbarButtonStyle}" Click="FillColumnButton_OnClick">填充列</Button>
                            <Button Name="CalculateBlankSizeButton" Style="{StaticResource ToolbarWideButtonStyle}" Click="CalculateBlankSizeButton_OnClick">计算下料</Button>
                            <Button Name="FindReplaceButton" Style="{StaticResource ToolbarWideButtonStyle}" Click="FindReplaceButton_OnClick">查找替换</Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource ToolbarGroupBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ToolbarGroupTitleStyle}">显示导出</TextBlock>
                        <WrapPanel>
                            <Button Name="IncreaseRowHeightButton" Style="{StaticResource ToolbarButtonStyle}" Click="IncreaseRowHeightButton_OnClick">行高+</Button>
                            <Button Name="DecreaseRowHeightButton" Style="{StaticResource ToolbarButtonStyle}" Click="DecreaseRowHeightButton_OnClick">行高-</Button>
                            <Button Name="ThumbnailButton" Style="{StaticResource ToolbarButtonStyle}" Click="ThumbnailButton_OnClick">缩略图关</Button>
                            <Button Name="ExportCsvButton" Style="{StaticResource ToolbarButtonStyle}" Click="ExportCsvButton_OnClick">导出 CSV</Button>
                            <Button Name="ExportExcelButton" Style="{StaticResource ToolbarWideButtonStyle}" Click="ExportExcelButton_OnClick">导出 Excel</Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <TextBlock Grid.Column="5"
                           Name="StatusText"
                           Margin="12,0,0,8"
                           VerticalAlignment="Center"
                           Foreground="DimGray"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="1" Margin="0,10,0,10">
            <TextBlock Style="{StaticResource ToolbarOptionTextStyle}">读取方式</TextBlock>
            <ComboBox Name="ReadModeComboBox" Width="170" Height="30" Margin="0,0,20,8" SelectedIndex="0">
                <ComboBoxItem>按BOM读取</ComboBoxItem>
                <ComboBoxItem>全部读取</ComboBoxItem>
            </ComboBox>
            <TextBlock Style="{StaticResource ToolbarOptionTextStyle}">读取位置</TextBlock>
            <ComboBox Name="PropertySourceComboBox" Width="180" Height="30" Margin="0,0,20,8" SelectedIndex="1">
                <ComboBoxItem>从自定义属性读取</ComboBoxItem>
                <ComboBoxItem>从当前配置属性读取</ComboBoxItem>
            </ComboBox>
            <CheckBox Name="SkipVirtualCheckBox" IsChecked="True" Margin="0,0,20,8" VerticalAlignment="Center">不读取虚拟件</CheckBox>
            <CheckBox Name="GroupByConfigCheckBox" IsChecked="True" Margin="0,0,20,8" VerticalAlignment="Center">按配置分组</CheckBox>
        </WrapPanel>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Name="ProgressText" VerticalAlignment="Center" Foreground="DimGray">就绪</TextBlock>
            <ProgressBar Grid.Column="1" Name="ReadProgressBar" Height="16" Minimum="0" Maximum="100" Value="0"/>
        </Grid>

        <DataGrid Grid.Row="2"
                  Name="BomGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  Margin="0"
                  RowHeight="28"
                  FontSize="12"
                  Tag="20"
                  SelectionMode="Extended"
                  SelectionUnit="Cell"
                  ClipboardCopyMode="None"
                  FrozenColumnCount="3"
                  GridLinesVisibility="All"
                  HeadersVisibility="All"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  VirtualizingPanel.ScrollUnit="Pixel"
                  VirtualizingPanel.CacheLength="1"
                  VirtualizingPanel.CacheLengthUnit="Page"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.IsDeferredScrollingEnabled="True"
                  CanUserResizeRows="False"
                  CanUserReorderColumns="True"
                  CanUserSortColumns="True"
                  PreviewMouseLeftButtonUp="BomGrid_OnPreviewMouseLeftButtonUp"
                  PreviewMouseRightButtonDown="BomGrid_OnPreviewMouseRightButtonDown"
                  PreviewKeyDown="BomGrid_OnPreviewKeyDown"
                  PreviewTextInput="BomGrid_OnPreviewTextInput"
                  CellEditEnding="BomGrid_OnCellEditEnding"
                  SelectedCellsChanged="BomGrid_OnSelectedCellsChanged"
                  CurrentCellChanged="BomGrid_OnCurrentCellChanged">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="复制" Click="CopyCellsMenuItem_OnClick"/>
                    <MenuItem Header="粘贴" Click="PasteCellsMenuItem_OnClick"/>
                    <Separator/>
                    <MenuItem Header="复制列" Click="CopyColumnButton_OnClick"/>
                    <MenuItem Header="填充列" Click="FillColumnButton_OnClick"/>
                    <MenuItem Header="查找替换" Click="FindReplaceButton_OnClick"/>
                    <Separator/>
                    <MenuItem Header="打开零件/装配体" Click="OpenModelMenuItem_OnClick"/>
                    <MenuItem Header="打开工程图" Click="OpenDrawingMenuItem_OnClick"/>
                    <Separator/>
                    <MenuItem Header="保存到 SW" Click="SaveToSwButton_OnClick"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="4,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter VerticalAlignment="Center"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="MinHeight" Value="36"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="8,0"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="类型" Width="56">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding DocumentIconPath}"
                                   ToolTip="{Binding DocumentType}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Width="{Binding Tag, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                   Height="{Binding Tag, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="工程图" Width="64">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding DrawingIconPath}"
                                   ToolTip="{Binding DrawingStatus}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Width="{Binding Tag, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                   Height="{Binding Tag, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="48">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="220"/>
                <DataGridTextColumn Header="配置" Binding="{Binding Configuration}" Width="90"/>
                <DataGridTextColumn Header="数量" Binding="{Binding Quantity}" Width="56">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="SW材料" Binding="{Binding Material}" Width="140">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasUnsetMaterial}" Value="True">
                                    <Setter Property="Background" Value="#FFFFD6D6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="完整路径" Binding="{Binding DirectoryPath}" Width="300">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOutsideMainAssemblyDirectory}" Value="True">
                                    <Setter Property="Background" Value="#FFFFD6D6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <RichTextBox Grid.Row="4" Name="LogTextBox" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
    </Grid>
</Window>
